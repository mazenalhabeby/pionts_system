# ─── Database ───
DATABASE_URL=postgresql://pionts_user:CHANGE_ME_STRONG_PASSWORD@postgres:5432/pionts_db
POSTGRES_USER=pionts_user
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=pionts_db

# ─── App ───
NODE_ENV=production
PORT=3000

# ─── Auth secrets (generate with: openssl rand -hex 32) ───
JWT_SECRET=CHANGE_ME
JWT_REFRESH_SECRET=CHANGE_ME
SESSION_SECRET=CHANGE_ME

# ─── Shopify integration ───
SHOPIFY_STORE=8bc.myshopify.com
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_ACCESS_TOKEN=
WEBHOOK_SECRET=

# ─── Admin ───
ADMIN_PASSWORD=CHANGE_ME

# ─── SMTP (optional — without these, emails are logged to console) ───
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM_EMAIL=
