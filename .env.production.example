# ─── Database ───
DATABASE_URL=postgresql://pionts_user:CHANGE_ME_STRONG_PASSWORD@postgres:5432/pionts_db
POSTGRES_USER=pionts_user
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=pionts_db

# ─── App ───
NODE_ENV=production
PORT=3000

# ─── URLs (required for CORS, emails, and redirects) ───
FRONTEND_URL=https://yourdomain.com
ADMIN_URL=https://yourdomain.com/admin
BACKEND_URL=https://yourdomain.com

# ─── Auth secrets (generate with: openssl rand -hex 32) ───
JWT_SECRET=CHANGE_ME
JWT_REFRESH_SECRET=CHANGE_ME
SESSION_SECRET=CHANGE_ME

# ─── Shopify integration (optional — for discount code creation) ───
SHOPIFY_STORE=your-store.myshopify.com
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_ACCESS_TOKEN=
WEBHOOK_SECRET=

# ─── Admin ───
ADMIN_PASSWORD=CHANGE_ME

# ─── SMTP (required for email OTP and notifications) ───
SMTP_HOST=smtp.yourprovider.com
SMTP_PORT=587
SMTP_USER=your-email@domain.com
SMTP_PASS=your-password
SMTP_FROM_EMAIL=no-reply@yourdomain.com

# ─── Google OAuth (optional — leave empty to disable social login) ───
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=
